rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Shops: publicly readable. Writes locked down (admin / console / server only).
    match /shops/{shopId} {
      allow read: if true;
      allow write: if false;

      // Broadcasts: publicly readable so followers can see history.
      // Creates happen server-side (admin / console) only.
      match /broadcasts/{broadcastId} {
        allow read: if true;
        allow write: if false;
      }

      // Followers: each user can create/delete only their own follower doc.
      match /followers/{uid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
        allow update: if false;
      }
    }

    // Users: each user owns their own doc and subcollections.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /following/{shopId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /devices/{token} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
