# Copy this file to .env and fill in the values before starting the server.

# Secret key used to sign table session tokens — use a long random string
KOF_TOKEN_SECRET=replace_with_a_long_random_secret

# Base URL the server is reachable at (used in QR codes)
KOF_PUBLIC_BASE_URL=http://192.168.1.x:3000

# Path to the SQLite database file
KOF_DB_PATH=kof.sqlite

# Directory where database backups are stored
KOF_BACKUP_DIR=backups

# How many days to keep backups
KOF_BACKUP_KEEP_DAYS=30

# How many days to retain completed/cancelled orders
KOF_ORDER_RETENTION_DAYS=30
